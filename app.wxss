/**app.wxss**/
page {
  background-color: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', sans-serif;
}

.container {
  padding: 20rpx;
}

.btn-primary {
  background-color: #1296db;
  color: white;
  border-radius: 8rpx;
}

.btn-danger {
  background-color: #ff4d4f;
  color: white;
  border-radius: 8rpx;
}

.card {
  background: white;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.08);
}

.price {
  color: #ff4d4f;
  font-weight: bold;
  font-size: 32rpx;
}

.price-small {
  font-size: 24rpx;
}
