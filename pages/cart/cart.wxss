/* pages/cart/cart.wxss */
.cart-item {
  background: white;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
}

.cart-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 8rpx;
  margin-right: 20rpx;
}

.cart-info {
  flex: 1;
}

.cart-name {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 12rpx;
}

.cart-price {
  margin-bottom: 12rpx;
}

.cart-quantity {
  display: flex;
  align-items: center;
}

.quantity-btn {
  width: 56rpx;
  height: 56rpx;
  line-height: 56rpx;
  padding: 0;
  font-size: 32rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
}

.quantity-text {
  margin: 0 20rpx;
  font-size: 28rpx;
  min-width: 40rpx;
  text-align: center;
}

.cart-actions {
  margin-left: 20rpx;
}

.cart-summary {
  margin-top: 40rpx;
}

.summary-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 32rpx;
  margin-bottom: 30rpx;
}

.checkout-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
}

.empty {
  text-align: center;
  padding: 200rpx 40rpx;
}

.empty-text {
  display: block;
  font-size: 28rpx;
  color: #999;
  margin-bottom: 40rpx;
}
