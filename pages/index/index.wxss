/* pages/index/index.wxss */
.banner {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 80rpx 40rpx;
  text-align: center;
  color: white;
  border-radius: 12rpx;
  margin-bottom: 40rpx;
}

.banner-title {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  margin-bottom: 16rpx;
}

.banner-subtitle {
  display: block;
  font-size: 28rpx;
  opacity: 0.9;
}

.section {
  margin-bottom: 40rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
}

.product-list {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.product-item {
  background: white;
  border-radius: 12rpx;
  overflow: hidden;
}

.item-image {
  width: 100%;
  height: 340rpx;
}

.item-info {
  padding: 20rpx;
}

.item-name {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.item-price {
  font-size: 28rpx;
}

.empty-hint {
  text-align: center;
  padding: 80rpx 0;
  color: #999;
  font-size: 28rpx;
}

.view-more-btn {
  margin-top: 30rpx;
  background: white;
  color: #1296db;
  border: 1rpx solid #1296db;
  border-radius: 8rpx;
}
