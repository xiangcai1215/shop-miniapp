<!--pages/admin/upload.wxml-->
<view class="container">
  <view class="card">
    <view class="form-title">上传商品</view>
    
    <!-- 商品图片 -->
    <view class="form-item">
      <view class="label">商品图片</view>
      <view class="image-upload">
        <block wx:if="{{imageUrl}}">
          <image src="{{imageUrl}}" mode="aspectFill" class="preview-image"></image>
          <view class="remove-btn" bindtap="removeImage">×</view>
        </block>
        <view wx:else class="upload-btn" bindtap="chooseImage">
          <text class="icon">+</text>
          <text class="text">选择图片</text>
        </view>
      </view>
    </view>
    
    <!-- 商品名称 -->
    <view class="form-item">
      <view class="label">商品名称</view>
      <input class="input" placeholder="请输入商品名称" value="{{name}}" bindinput="onNameInput"/>
    </view>
    
    <!-- 商品价格 -->
    <view class="form-item">
      <view class="label">商品价格(元)</view>
      <input class="input" type="digit" placeholder="请输入价格" value="{{price}}" bindinput="onPriceInput"/>
    </view>
    
    <!-- 商品库存 -->
    <view class="form-item">
      <view class="label">库存数量</view>
      <input class="input" type="number" placeholder="请输入库存" value="{{stock}}" bindinput="onStockInput"/>
    </view>
    
    <!-- 商品描述 -->
    <view class="form-item">
      <view class="label">商品描述</view>
      <textarea class="textarea" placeholder="请输入商品描述" value="{{description}}" bindinput="onDescInput" maxlength="500"></textarea>
    </view>
    
    <!-- 提交按钮 -->
    <button class="btn-primary submit-btn" bindtap="submitProduct">发布商品</button>
  </view>
  
  <!-- 已上传商品列表 -->
  <view class="product-list" wx:if="{{products.length > 0}}">
    <view class="list-title">已上传商品</view>
    <view class="product-item" wx:for="{{products}}" wx:key="id">
      <image src="{{item.imageUrl}}" mode="aspectFill" class="item-image"></image>
      <view class="item-info">
        <view class="item-name">{{item.name}}</view>
        <view class="item-price price-small">¥{{item.price}}</view>
        <view class="item-stock">库存: {{item.stock}}</view>
      </view>
      <view class="item-actions">
        <button class="btn-danger mini-btn" bindtap="deleteProduct" data-id="{{item.id}}">删除</button>
      </view>
    </view>
  </view>
</view>
